/* Grinta TUI - "Mission Control" Theme */

Screen {
    background: #0a0e14;
    color: #d8dee9;
}

/* ── TopBar ────────────────────────────────────────── */
TopBar {
    height: 1;
    background: #192036;
    color: #65737e;
    padding: 0 2;
}

/* ── MetricsGrid ───────────────────────────────────── */
MetricsGrid {
    height: 5;
    background: #0a0e14;
    padding: 0 1;
    margin-bottom: 1;
}

MetricsCard {
    height: 5;
    width: 1fr;
    background: #131b2e;
    border: solid #3a4f6a;
    padding: 0 1;
    margin: 0 0 0 1;
    color: #d8dee9;
}

MetricsCard:first-of-type {
    margin-left: 0;
}

/* ── ReasoningPanel ────────────────────────────────── */
ReasoningPanel {
    height: auto;
    max-height: 3;
    background: #0f1525;
    border-left: solid #5fb3b3;
    padding: 0 2;
    margin-bottom: 1;
    display: none;
}

ReasoningPanel.active {
    display: block;
}

/* ── Transcript ────────────────────────────────────── */
Transcript {
    background: #0a0e14;
    scrollbar-color: #33405d #0a0e14;
    scrollbar-size: 1 8;
    padding: 0 1;
}

/* ── InputBar ──────────────────────────────────────── */
InputBar {
    height: 3;
    background: #0f1525;
    border-top: solid #1b2b34;
    padding: 0 1;
    dock: bottom;
}

InputBar Static {
    color: #5fb3b3;
    text-style: bold;
    padding: 0 1;
    content-align: center middle;
    width: 2;
}

InputBar TextArea {
    background: #0a0e14;
    color: #d8dee9;
    border: none;
    padding: 1 2;
}

InputBar TextArea:focus {
    border: none;
    background: #0f151c;
}

InputBar.processing TextArea {
    background: #0f151c;
}

/* ── FooterBar ─────────────────────────────────────── */
FooterBar {
    height: 1;
    background: #192036;
    color: #65737e;
    dock: bottom;
    text-align: center;
    content-align: center middle;
}

FooterBar.hidden {
    display: none;
}

/* ── Confirmation dialog ───────────────────────────── */
GrintaConfirmDialog {
    background: #0f1525;
    border: solid #1b2b34;
    padding: 2 4;
    width: 60;
    align: center top;
}

GrintaConfirmDialog .title {
    color: #5fb3b3;
    text-style: bold;
    margin-bottom: 1;
}

GrintaConfirmDialog .body {
    color: #d8dee9;
    margin-bottom: 2;
}

GrintaConfirmDialog Button {
    background: #0f1525;
    color: #d8dee9;
    border: solid #1b2b34;
    margin: 0 1;
}

GrintaConfirmDialog Button:hover {
    background: #5fb3b3;
    color: #0a0e14;
    border: solid #5fb3b3;
}

/* ── Utility classes ───────────────────────────────── */
.hidden {
    display: none;
}
