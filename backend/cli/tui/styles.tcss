/* Grinta TUI — Clean minimal layout */

Screen {
    background: #060a14;
    color: #e9e9e9;
}

/* ── TopBar ────────────────────────────────────────── */
TopBar {
    height: 1;
    background: #060a14;
    color: #969aad;
    padding: 0 2;
    dock: top;
}

TopBar .topbar-title {
    width: 15%;
    color: #91abec;
    text-style: bold;
}

TopBar .topbar-host {
    width: 70%;
    content-align: center middle;
    color: #bbc8e8;
    text-style: bold;
}

TopBar .topbar-help {
    width: 15%;
    content-align: right middle;
    color: #8f9fc1;
}

/* ── Transcript ────────────────────────────────────── */
Transcript {
    background: #060a14;
    scrollbar-color: #33405d #161e31;
    scrollbar-color-hover: #404f71 #161e31;
    scrollbar-color-active: #4f608a #161e31;
    scrollbar-size: 1 8;
    padding: 0 1;
    margin: 0;
    height: 1fr;
}

Transcript RichLog,
RichLog#transcript-log {
    background: #060a14;
    width: 100%;
    text-wrap: wrap;
    overflow-x: auto;
}

/* ── InputBar ──────────────────────────────────────── */
InputBar {
    height: 3;
    background: #060a14;
    border: solid #384673;
    padding: 0 2;
    margin: 0;
}

HUD {
    height: 1;
    background: #060a14;
    color: #969aad;
    padding: 0 2;
}

InputBar Input {
    background: #0d1525;
    color: #e9e9e9;
    border: none;
    padding: 1 1;
    height: 100%;
}

InputBar Input:focus {
    border: none;
    background: #0d1525;
}

InputBar.processing Input {
    background: #060a14;
}

/* ── HUD Bar ────────────────────────────────────────── */
HUD {
    height: 1;
    background: #060a14;
    color: #969aad;
    dock: bottom;
    padding: 0 2;
}

/* ── Confirmation dialog ───────────────────────────── */
GrintaConfirmDialog {
    background: #060a14 70%;
}

GrintaConfirmDialog > Vertical {
    background: #060a14;
    border: tall #384673;
    padding: 2 4;
    width: 60;
    align: center top;
}

GrintaConfirmDialog .title {
    color: #91abec;
    text-style: bold;
    margin-bottom: 1;
}

GrintaConfirmDialog .body {
    color: #e9e9e9;
    margin-bottom: 2;
}

GrintaConfirmDialog Button {
    background: #282c42;
    color: #e9e9e9;
    border-top: tall #54597b;
    border-bottom: tall #171922;
    margin: 0 1;
}

GrintaConfirmDialog Button:hover {
    background: #383e5c;
    border-top: tall #69709a;
    border-bottom: tall #171922;
}

GrintaConfirmDialog Button.-primary {
    background: #192c5b;
    border-top: tall #425894;
    border-bottom: tall #0d1525;
}

GrintaConfirmDialog Button.-primary:hover {
    background: #203875;
    border-top: tall #425894;
    border-bottom: tall #0d1525;
}

/* ── Toast notifications ──────────────────────────── */
Toast {
    background: #060a14;
    border-right: wide #060a14;
}

Toast.-information {
    border-left: wide #91abec;
}

Toast.-success {
    border-left: wide #5bd088;
}

Toast.-warning {
    border-left: wide #f0e357;
}

Toast.-error {
    border-left: wide #f05757;
}

/* ── Utility classes ───────────────────────────────── */
.hidden {
    display: none;
}
