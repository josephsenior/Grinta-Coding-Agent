/* Grinta TUI — Mission Control layout */

Screen {
    background: #060a14;
    color: #e9e9e9;
}


/* ── Layout Containers ──────────────────────────────── */
#main-layout {
    layout: horizontal;
    height: 1fr;
}

#transcript-container {
    width: 70%;
    height: 100%;
    background: #060a14;
}

#sidebar-container {
    width: 30%;
    height: 100%;
    background: #080c18;
    border-left: tall #1b233a;
}

/* ── Transcript ────────────────────────────────────── */
Transcript {
    background: #060a14;
    scrollbar-color: #33405d #161e31;
    scrollbar-color-hover: #404f71 #161e31;
    scrollbar-color-active: #4f608a #161e31;
    scrollbar-size: 1 8;
    padding: 1 2;
    height: 1fr;
    overflow-x: hidden;
}

#main-display {
    width: 100%;
}

/* ── Info Sidebar ──────────────────────────────────── */
InfoSidebar {
    background: #080c18;
    padding: 1 1;
    scrollbar-color: #33405d #161e31;
    scrollbar-color-hover: #404f71 #161e31;
    scrollbar-color-active: #4f608a #161e31;
    scrollbar-size: 1 8;
    overflow-y: auto;
    overflow-x: hidden;
}

#sidebar-display {
    width: 100%;
}

/* ── InputBar ──────────────────────────────────────── */
InputBar {
    height: 4;
    background: #0d1a2d;
    border-top: solid #1b233a;
    padding: 0 2;
    layout: horizontal;
}

InputBar TextArea {
    background: #16263d;
    color: #c8d4e8;
    border: none;
    padding: 0 1;
    width: 100%;
    height: 3;
}

#spinner {
    width: 3;
    height: 3;
    content-align: center middle;
    color: #91abec;
    margin-right: 1;
}

#spinner.-hidden {
    display: none;
}

/* ── HUD Bar ────────────────────────────────────────── */
HUD,
#hud-bar {
    height: auto;
    background: #0a1525;
    color: #969aad;
    padding: 1 2 0 2;
}

#hud-line-1 {
    height: 1;
    text-style: bold;
}

#hud-line-2 {
    height: 1;
    margin-top: 1;
}

/* ── Confirmation dialog ───────────────────────────── */
GrintaConfirmDialog {
    background: #060a14 70%;
}

GrintaConfirmDialog > Vertical {
    background: #060a14;
    border: tall #384673;
    padding: 2 4;
    width: 60;
    align: center middle;
}

GrintaConfirmDialog .title {
    color: #91abec;
    text-style: bold;
    margin-bottom: 1;
}

GrintaConfirmDialog .body {
    color: #e9e9e9;
    margin-bottom: 2;
}

GrintaConfirmDialog Button {
    background: #282c42;
    color: #e9e9e9;
    border-top: tall #54597b;
    border-bottom: tall #171922;
    margin: 0 1;
}

/* ── Toast notifications ──────────────────────────── */
Toast {
    background: #060a14;
    border-right: wide #060a14;
}

Toast.-success { border-left: wide #5bd088; }
Toast.-error { border-left: wide #f05757; }

/* ── Utility ───────────────────────────────────────── */
.hidden { display: none; }
