/* Grinta TUI — Mission Control layout */

Screen {
    background: #060a14;
    color: #e9e9e9;
}


/* ── Layout Containers ──────────────────────────────── */
#main-layout {
    layout: horizontal;
    height: 1fr;
}

#sidebar-container {
    width: 30%;
    height: 100%;
    background: #080c18;
    border-left: solid #1e293b;
}

#sidebar-container.-hidden {
    display: none;
}

/* ── Transcript ────────────────────────────────────── */
Transcript {
    background: #060a14;
    scrollbar-color: #33405d #161e31;
    scrollbar-color-hover: #404f71 #161e31;
    scrollbar-color-active: #4f608a #161e31;
    scrollbar-size: 1 0;
    padding: 1 2;
    height: 1fr;
    layout: vertical;
    overflow-x: hidden;
}

#main-display {
    width: 70%;
    height: 100%;
    background: #060a14;
    color: #e9e9e9;
    scrollbar-color: #33405d #161e31;
    scrollbar-color-hover: #404f71 #161e31;
    scrollbar-color-active: #4f608a #161e31;
    scrollbar-size: 1 0;
    padding: 1 2;
}

/* ── Interactive Components Focus & Hover ──────────── */
ActivityCard {
    transition: background 150ms, border-left 150ms;
    border-left: transparent;
    padding: 0 1;
}

ActivityCard:hover {
    background: #0a1122;
}

ActivityCard:focus {
    background: #0d162a;
    border-left: solid #91abec;
}

CollapsibleSection {
    transition: background 150ms, border-left 150ms;
    border-left: transparent;
    padding: 0 1;
}

CollapsibleSection:hover {
    background: #0a1122;
}

CollapsibleSection:focus {
    background: #0d162a;
    border-left: solid #5eead4;
}

.turn-summary {
    color: #5eead4;
    text-style: bold;
    margin-bottom: 1;
}

/* ── Info Sidebar ──────────────────────────────────── */
InfoSidebar {
    background: #080c18;
    padding: 1 1;
    scrollbar-size: 0 0;
    overflow-y: auto;
    overflow-x: hidden;
}

SidebarRow {
    padding: 0 1;
    margin: 0 0 1 0;
    background: transparent;
    transition: background 150ms, color 150ms;
    width: 100%;
    height: auto;
}

SidebarRow:hover {
    background: #101c36;
    color: #e9e9e9;
}

SidebarRow:focus {
    background: #15274d;
    color: #ffffff;
    border-left: solid #91abec;
}

/* ── InputBar ──────────────────────────────────────── */
InputBar {
    height: 4;
    background: #070e1b;
    border-top: solid #1e293b;
    padding: 0 2;
    layout: horizontal;
}

InputBar TextArea {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
    padding: 0 1;
    width: 100%;
    height: 3;
    transition: background 150ms, border-left 150ms;
}

InputBar TextArea:focus {
    background: #12223a;
    border-left: solid #3b82f6;
}

#spinner {
    width: 3;
    height: 3;
    content-align: center middle;
    color: #91abec;
    margin-right: 1;
}

#spinner.-hidden {
    display: none;
}

/* ── HUD Bar ────────────────────────────────────────── */
HUD,
#hud-bar {
    height: auto;
    background: #0a1525;
    color: #969aad;
    padding: 1 2;
}

#hud-line-1 {
    height: 1;
    text-style: bold;
}

#hud-line-2 {
    height: 1;
    margin-top: 1;
}

#hud-line-3 {
    height: 1;
    margin-top: 0;
    color: #8f9fc1;
}

#hud-line-4 {
    height: auto;
    margin-top: 0;
    border-top: solid #15233c;
    padding-top: 0;
    color: #54597b;
}

/* ── Textual Generic Controls Design System ──────────────── */

/* Inputs & Textareas */
Input {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
    transition: background 150ms, border-left 150ms;
}

Input:focus {
    background: #12223a;
    border-left: solid #91abec;
}

/* Checkbox */
Checkbox {
    background: transparent;
    color: #cbd5e1;
}

Checkbox:hover {
    color: #ffffff;
}

Checkbox > .checkbox--box {
    background: #0f1c30;
    color: #91abec;
}

Checkbox.-on > .checkbox--box {
    background: #15274d;
    color: #5eead4;
}

/* Select */
Select {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
}

Select:focus {
    border-left: solid #91abec;
}

/* Buttons */
Button {
    background: #101c36;
    color: #e9e9e9;
    border: none;
    padding: 1 4;
    min-width: 16;
    height: 3;
    transition: background 150ms, color 150ms;
}

Button:hover {
    background: #15274d;
    color: #ffffff;
}

Button:focus {
    background: #1e3a70;
    color: #ffffff;
    border-left: solid #91abec;
}

Button.-active {
    background: #2563eb;
    color: #ffffff;
}

Button.primary {
    background: #1e3a70;
    color: #ffffff;
}

Button.primary:hover {
    background: #2563eb;
    color: #ffffff;
}

Button.primary:focus {
    border-left: solid #5eead4;
}

Button.-error {
    background: #451a1a;
    color: #fd8383;
}

Button.-error:hover {
    background: #f05757;
    color: #ffffff;
}

Button.-error:focus {
    border-left: solid #fd8383;
}

/* Data Table */
DataTable {
    background: #080c18;
    color: #cbd5e1;
    scrollbar-color: #33405d #161e31;
}

DataTable > .datatable--header {
    background: #0f1c30;
    color: #ffffff;
    text-style: bold;
}

DataTable > .datatable--row-hover {
    background: #101c36;
}

DataTable > .datatable--row-selected {
    background: #15274d;
    color: #ffffff;
}

/* ── Confirmation dialog ───────────────────────────── */
GrintaConfirmDialog {
    background: #060a14 70%;
    align: center middle;
}

GrintaConfirmDialog > Vertical {
    background: #080c18;
    border: round #1e293b;
    padding: 2 4;
    width: 60;
    align: center middle;
    height: auto;
}

GrintaConfirmDialog .title {
    color: #91abec;
    text-style: bold;
    margin-bottom: 1;
}

GrintaConfirmDialog .body {
    color: #cbd5e1;
    margin-bottom: 2;
}

GrintaConfirmDialog .buttons-row {
    height: auto;
    align-horizontal: right;
    margin-top: 1;
}

GrintaConfirmDialog Button {
    margin: 0 1;
}

GrintaSettingsDialog,
GrintaSessionsDialog,
GrintaAddSkillDialog,
GrintaAddMCPDialog {
    background: #060a14 70%;
    align: center middle;
}

#settings-dialog,
#sessions-dialog {
    background: #080c18;
    border: round #1e293b;
    padding: 2 4;
    width: 92;
    max-height: 36;
    align: center middle;
}

#settings-dialog .title,
#sessions-dialog .title {
    color: #91abec;
    text-style: bold;
    margin-bottom: 2;
}

#settings-dialog .field-label {
    color: #969aad;
    margin-top: 1;
}

#settings-current-key,
#settings-feedback,
#sessions-feedback {
    color: #8f9fc1;
    margin-top: 1;
}

#settings-model,
#settings-api-key,
#settings-budget {
    margin-bottom: 1;
}

#settings-dialog TextArea {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
    padding: 0 1;
    width: 100%;
    height: 10;
    margin-bottom: 1;
    transition: background 150ms, border-left 150ms;
}

#settings-dialog TextArea:focus {
    background: #12223a;
    border-left: solid #91abec;
}

#settings-buttons,
#sessions-buttons {
    height: auto;
    align-horizontal: right;
    margin-top: 2;
}

#settings-buttons Button,
#sessions-buttons Button {
    margin-left: 2;
}

#sessions-filters {
    height: auto;
    margin-bottom: 1;
}

#sessions-search {
    width: 1fr;
}

#sessions-sort {
    width: 18;
    margin-left: 1;
}

#sessions-limit {
    width: 10;
    margin-left: 1;
}

#sessions-refresh {
    margin-left: 1;
}

#sessions-table {
    height: 14;
    margin-bottom: 1;
    border: none;
}

#sessions-preview {
    height: 8;
    border: round #1e293b;
    padding: 1 2;
    background: #060a14;
    color: #cbd5e1;
}

/* ── Toast notifications ──────────────────────────── */
Toast {
    background: #060a14;
    border-right: wide #060a14;
}

Toast.-success { border-left: wide #5bd088; }
Toast.-error { border-left: wide #f05757; }

/* ── Transcript Messages ────────────────────────────── */
UserMessage {
    width: 100%;
    height: auto;
    margin: 1 0;
    padding: 1 2;
    background: #091522;
    border-left: solid #14b8a6;
    color: #f8fafc;
}

AgentMessage {
    width: 100%;
    height: auto;
    margin: 1 0;
    padding: 1 2;
    background: #080c16;
    border-left: solid #6366f1;
    color: #cbd5e1;
}

ActivityCard .card-extra {
    width: 100%;
    height: auto;
    margin-left: 2;
    margin-top: 1;
    padding: 0 1;
}

/* ── Utility ───────────────────────────────────────── */
.hidden { display: none; }
