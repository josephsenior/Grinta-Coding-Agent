/* Grinta TUI — Mission Control layout */

Screen {
    background: #060a14;
    color: #e9e9e9;
}


/* ── Layout Containers ──────────────────────────────── */
#main-layout {
    layout: horizontal;
    height: 1fr;
}

#transcript-column {
    width: 70%;
    height: 100%;
    background: #060a14;
}

#sidebar-container {
    width: 30%;
    height: 100%;
    background: #080c18;
    border-left: solid #1e293b;
}

#sidebar-container.-hidden {
    display: none;
}

/* ── Transcript ────────────────────────────────────── */
Transcript {
    background: #060a14;
    scrollbar-color: #33405d #161e31;
    scrollbar-color-hover: #404f71 #161e31;
    scrollbar-color-active: #4f608a #161e31;
    scrollbar-size: 1 0;
    padding: 1 2 2 2;
    height: 1fr;
    layout: vertical;
    overflow-x: hidden;
}

#main-display {
    width: 100%;
    height: 100%;
    background: #060a14;
    color: #e9e9e9;
    scrollbar-color: #33405d #161e31;
    scrollbar-color-hover: #404f71 #161e31;
    scrollbar-color-active: #4f608a #161e31;
    scrollbar-size: 1 0;
    padding: 1 2;
}

/* ── Interactive Components Focus & Hover ──────────── */
ActivityCard {
    transition: background 150ms, border 150ms;
    border: round #1b233a;
    background: #08101d;
    padding: 0;
    margin: 0 0 1 0;
}

ActivityCard:hover {
    background: #0a1323;
    border: round #26365b;
}

ActivityCard:focus {
    background: #0d162a;
    border: round #4a5f99;
}

ActivityCard.processing {
    background: #091320;
    border: round #32416a;
}

ActivityCard.category-shell.processing,
ActivityCard.category-terminal.processing {
    border: round #3e557f;
}

ActivityCard .card-title {
    color: #7f8aa3;
    text-style: bold;
}

ActivityCard .card-header {
    color: #e9e9e9;
}

ActivityCard .card-secondary {
    color: #969aad;
}

ActivityCard .card-extra-wrap {
    border: round #15233c;
    background: #050b16;
}

ActivityCard.category-shell .card-extra-wrap,
ActivityCard.category-terminal .card-extra-wrap {
    border: round #24385c;
    background: #050913;
}

ActivityCard.category-files .card-extra-wrap {
    border: round #1f314f;
    background: #07101d;
}

CollapsibleSection {
    transition: background 150ms, border-left 150ms;
    border-left: transparent;
    padding: 0 1;
}

CollapsibleSection:hover {
    background: #0a1122;
}

CollapsibleSection:focus {
    background: #0d162a;
    border-left: solid #5eead4;
}

.turn-summary {
    width: 100%;
    height: 1;
    padding: 0 1;
    background: #071b21;
    color: #5eead4;
    margin-bottom: 1;
}

/* ── Info Sidebar ──────────────────────────────────── */
InfoSidebar {
    background: #080c18;
    padding: 1 1;
    scrollbar-size: 0 0;
    overflow-y: auto;
    overflow-x: hidden;
}

SidebarRow {
    padding: 0 1;
    margin: 0 0 1 0;
    background: transparent;
    transition: background 150ms, color 150ms;
    width: 100%;
    height: auto;
}

SidebarRow:hover {
    background: #101c36;
    color: #e9e9e9;
}

SidebarRow:focus {
    background: #15274d;
    color: #ffffff;
    border-left: solid #91abec;
}

/* ── InputBar ──────────────────────────────────────── */
InputBar {
    height: 4;
    background: #08101d;
    border-top: solid #1b233a;
    padding: 0 2;
    layout: horizontal;
}

InputBar TextArea {
    background: #0b1628;
    color: #c8d4e8;
    border: round #15233c;
    padding: 0 1;
    width: 100%;
    height: 3;
    transition: background 150ms, border 150ms;
}

InputBar TextArea:focus {
    background: #12223a;
    border: round #43548b;
}

#spinner {
    width: 3;
    height: 3;
    content-align: center middle;
    color: #91abec;
    margin-right: 1;
}

#spinner.-hidden {
    display: none;
}

/* ── HUD Bar ────────────────────────────────────────── */
HUD,
#hud-bar {
    height: auto;
    background: #0a1525;
    color: #969aad;
    padding: 1 2;
    border-top: solid #15233c;
}

#hud-line-1 {
    height: 1;
    text-style: bold;
}

#hud-line-2 {
    width: 1fr;
    height: 1;
    color: #8f9fc1;
}

#hud-line-2-row {
    height: auto;
    layout: horizontal;
    align-vertical: middle;
    margin-top: 0;
    border-top: solid #15233c;
    padding-top: 0;
}

#hud-autonomy {
    width: 34;
    height: 1;
    margin-right: 2;
    background: #0a1525;
    color: #8f9fc1;
}

#hud-autonomy:focus {
    background: #0d162a;
}

/* ── Textual Generic Controls Design System ──────────────── */

/* Inputs & Textareas */
Input {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
    transition: background 150ms, border-left 150ms;
}

Input:focus {
    background: #12223a;
    border-left: solid #91abec;
}

/* Checkbox */
Checkbox {
    background: transparent;
    color: #cbd5e1;
}

Checkbox:hover {
    color: #ffffff;
}

Checkbox > .checkbox--box {
    background: #0f1c30;
    color: #91abec;
}

Checkbox.-on > .checkbox--box {
    background: #15274d;
    color: #5eead4;
}

/* Select */
Select {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
}

Select:focus {
    border-left: solid #91abec;
}

/* Buttons */
Button {
    background: #101c36;
    color: #e9e9e9;
    border: none;
    padding: 1 4;
    min-width: 16;
    height: 3;
    transition: background 150ms, color 150ms;
}

Button:hover {
    background: #15274d;
    color: #ffffff;
}

Button:focus {
    background: #1e3a70;
    color: #ffffff;
    border-left: solid #91abec;
}

Button.-active {
    background: #2563eb;
    color: #ffffff;
}

Button.primary {
    background: #1e3a70;
    color: #ffffff;
}

Button.primary:hover {
    background: #2563eb;
    color: #ffffff;
}

Button.primary:focus {
    border-left: solid #5eead4;
}

Button.-error {
    background: #451a1a;
    color: #fd8383;
}

Button.-error:hover {
    background: #f05757;
    color: #ffffff;
}

Button.-error:focus {
    border-left: solid #fd8383;
}

/* Data Table */
DataTable {
    background: #080c18;
    color: #cbd5e1;
    scrollbar-color: #33405d #161e31;
}

DataTable > .datatable--header {
    background: #0f1c30;
    color: #ffffff;
    text-style: bold;
}

DataTable > .datatable--row-hover {
    background: #101c36;
}

DataTable > .datatable--row-selected {
    background: #15274d;
    color: #ffffff;
}

/* ── Confirmation dialog ───────────────────────────── */
GrintaConfirmDialog {
    background: #060a14 70%;
    align: center middle;
}

GrintaConfirmDialog > Vertical {
    background: #080c18;
    border: round #1e293b;
    padding: 2 4;
    width: 60;
    align: center middle;
    height: auto;
}

GrintaConfirmDialog .title {
    color: #91abec;
    text-style: bold;
    margin-bottom: 1;
}

GrintaConfirmDialog .body {
    color: #cbd5e1;
    margin-bottom: 2;
}

GrintaConfirmDialog .buttons-row {
    height: auto;
    align-horizontal: right;
    margin-top: 1;
}

GrintaConfirmDialog Button {
    margin: 0 1;
}

GrintaSettingsDialog,
GrintaSessionsDialog,
GrintaAddSkillDialog,
GrintaAddMCPDialog,
GrintaHelpDialog {
    background: #060a14 70%;
    align: center middle;
}

#settings-dialog,
#sessions-dialog,
#help-dialog {
    background: #080c18;
    border: round #1e293b;
    padding: 2 4;
    width: 92;
    max-height: 36;
    align: center middle;
}

#settings-dialog .title,
#sessions-dialog .title,
#help-dialog .title {
    color: #91abec;
    text-style: bold;
    margin-bottom: 2;
}

#settings-dialog .field-label {
    color: #969aad;
    margin-top: 1;
}

#settings-current-key,
#settings-feedback,
#sessions-feedback {
    color: #8f9fc1;
    margin-top: 1;
}

#settings-model,
#settings-api-key,
#settings-budget {
    margin-bottom: 1;
}

#settings-dialog TextArea {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
    padding: 0 1;
    width: 100%;
    height: 10;
    margin-bottom: 1;
    transition: background 150ms, border-left 150ms;
}

#settings-dialog TextArea:focus {
    background: #12223a;
    border-left: solid #91abec;
}

#settings-buttons,
#sessions-buttons,
#help-buttons {
    height: auto;
    align-horizontal: right;
    margin-top: 2;
}

#settings-buttons Button,
#sessions-buttons Button,
#help-buttons Button {
    margin-left: 2;
}

#sessions-filters {
    height: auto;
    margin-bottom: 1;
}

#sessions-search {
    width: 1fr;
}

#sessions-sort {
    width: 18;
    margin-left: 1;
}

#sessions-limit {
    width: 10;
    margin-left: 1;
}

#sessions-refresh {
    margin-left: 1;
}

#sessions-table {
    height: 14;
    margin-bottom: 1;
    border: none;
}

#sessions-preview {
    height: 12;
    border: round #1e293b;
    padding: 1 2;
    background: #060a14;
    color: #cbd5e1;
}

#help-body {
    height: auto;
    color: #cbd5e1;
    border: round #1e293b;
    background: #060a14;
    padding: 1 2;
}

/* ── Toast notifications ──────────────────────────── */
Toast {
    background: #060a14;
    border-right: wide #060a14;
}

Toast.-success { border-left: wide #5bd088; }
Toast.-error { border-left: wide #f05757; }

/* ── Transcript Messages ────────────────────────────── */
UserMessage {
    width: 100%;
    height: auto;
    margin: 1 0;
    padding: 1 2;
    background: #091522;
    border: round #18485a;
    color: #f8fafc;
}

AgentMessage {
    width: 100%;
    height: auto;
    margin: 1 0;
    padding: 1 2;
    background: #080c16;
    border: none;
    color: #cbd5e1;
}

/* ── Utility ───────────────────────────────────────── */
.hidden { display: none; }
