/* Grinta TUI — Clean minimal layout */

Screen {
    background: #060a14;
    color: #e9e9e9;
}

/* ── TopBar ────────────────────────────────────────── */
TopBar {
    height: 1;
    background: #060a14;
    color: #969aad;
    padding: 0 2;
    dock: top;
}

TopBar .topbar-title {
    width: 15%;
    color: #91abec;
    text-style: bold;
}

TopBar .topbar-host {
    width: 70%;
    content-align: center middle;
    color: #bbc8e8;
    text-style: bold;
}

TopBar .topbar-help {
    width: 15%;
    content-align: right middle;
    color: #8f9fc1;
}

/* ── Transcript ────────────────────────────────────── */
Transcript {
    background: #060a14;
    scrollbar-color: #33405d #161e31;
    scrollbar-color-hover: #404f71 #161e31;
    scrollbar-color-active: #4f608a #161e31;
    scrollbar-size: 1 8;
    padding: 0 1;
    margin: 0;
    height: 1fr;
    overflow-x: hidden;
}

Transcript RichLog,
RichLog#transcript-log {
    background: #060a14;
    width: 100%;
    overflow-x: hidden;
}

/* ── InputBar ──────────────────────────────────────── */
InputBar {
    height: 3;
    background: #0d1a2d;
    border: none;
    margin: 0;
    layout: horizontal;
}

InputBar TextArea {
    background: #0d1a2d;
    color: #c8d4e8;
    border: none;
    padding: 1 4;
    width: 100%;
    height: 3;
}

InputBar TextArea:focus {
    border: none;
    background: #0d1a2d;
    color: #c8d4e8;
}

/* ── Thinking Block ────────────────────────────────── */
ThinkingBlock {
    background: #0a1225;
    border: solid #1b2a4a;
    margin: 0 2;
    padding: 0 1;
    height: auto;
    max-height: 10;
    overflow-y: auto;
}

ThinkingBlock.-hidden {
    display: none;
}

/* ── Spinner ────────────────────────────────────────── */
#spinner {
    width: 2;
    height: 3;
    content-align: center middle;
    color: #91abec;
}

#spinner.-hidden {
    display: none;
}

/* ── Stats Panel ────────────────────────────────────── */
InputStats {
    height: 3;
    background: #0a1525;
    color: #969aad;
    padding: 1 4;
    dock: bottom;
}

/* ── Memory Manager Modal ────────────────────────────── */
MemoryManagerModal {
    background: #060a14 80%;
}

MemoryManagerModal > Vertical {
    background: #060a14;
    border: tall #384673;
    padding: 2 4;
    width: 60;
    align: center top;
}

MemoryManagerModal .title {
    color: #91abec;
    text-style: bold;
    margin-bottom: 1;
}

MemoryManagerModal .sep {
    color: #1b233a;
    margin-bottom: 1;
}

MemoryManagerModal .stat-row {
    color: #e9e9e9;
    margin-bottom: 0;
}

MemoryManagerModal .spacer {
    margin: 1 0;
}

MemoryManagerModal .hint {
    color: #969aad;
    margin-bottom: 2;
}

MemoryManagerModal Button {
    background: #192c5b;
    border-top: tall #425894;
    border-bottom: tall #0d1525;
}

MemoryManagerModal Button:hover {
    background: #203875;
    border-top: tall #425894;
    border-bottom: tall #0d1525;
}

/* ── Confirmation dialog ───────────────────────────── */
GrintaConfirmDialog {
    background: #060a14 70%;
}

GrintaConfirmDialog > Vertical {
    background: #060a14;
    border: tall #384673;
    padding: 2 4;
    width: 60;
    align: center top;
}

GrintaConfirmDialog .title {
    color: #91abec;
    text-style: bold;
    margin-bottom: 1;
}

GrintaConfirmDialog .body {
    color: #e9e9e9;
    margin-bottom: 2;
}

GrintaConfirmDialog Button {
    background: #282c42;
    color: #e9e9e9;
    border-top: tall #54597b;
    border-bottom: tall #171922;
    margin: 0 1;
}

GrintaConfirmDialog Button:hover {
    background: #383e5c;
    border-top: tall #69709a;
    border-bottom: tall #171922;
}

GrintaConfirmDialog Button.-primary {
    background: #192c5b;
    border-top: tall #425894;
    border-bottom: tall #0d1525;
}

GrintaConfirmDialog Button.-primary:hover {
    background: #203875;
    border-top: tall #425894;
    border-bottom: tall #0d1525;
}

/* ── Toast notifications ──────────────────────────── */
Toast {
    background: #060a14;
    border-right: wide #060a14;
}

Toast.-information {
    border-left: wide #91abec;
}

Toast.-success {
    border-left: wide #5bd088;
}

Toast.-warning {
    border-left: wide #f0e357;
}

Toast.-error {
    border-left: wide #f05757;
}

/* ── Utility classes ───────────────────────────────── */
.hidden {
    display: none;
}
