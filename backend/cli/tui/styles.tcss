/* Grinta TUI — Mission Control layout */

Screen {
    background: #060a14;
    color: #e9e9e9;
}


/* ── Layout Containers ──────────────────────────────── */
#app-layout {
    layout: horizontal;
    height: 100%;
}

#left-column {
    width: 78%;
    height: 100%;
    background: #060a14;
}

#sidebar {
    width: 22%;
    height: 100%;
    layout: vertical;
    background: #080c18;
    border-left: solid #1e293b;
}

#sidebar.-hidden {
    display: none;
}

#sidebar-container {
    height: 1fr;
    scrollbar-color: #475569 #0f172a;
    scrollbar-color-hover: #64748b #0f172a;
    scrollbar-color-active: #94a3b8 #0f172a;
    scrollbar-size: 0 1;
}

/* ── Transcript ────────────────────────────────────── */
Transcript {
    background: #060a14;
    scrollbar-size-vertical: 1;
    scrollbar-size-horizontal: 0;
    scrollbar-color: #334155 #060a14;
    scrollbar-color-hover: #475569 #060a14;
    scrollbar-color-active: #64748b #060a14;
    padding: 2 2 3 2;
    height: 1fr;
    layout: vertical;
    overflow-x: hidden;
}

/* Extra breathing room between transcript blocks */
Transcript > UserMessage,
Transcript > AgentMessage,
Transcript > LiveResponse,
Transcript > ThinkingIndicator,
Transcript > ErrorBlock,
Transcript > TranscriptNotice,
Transcript > OrientLine,
Transcript > CollapsibleSection,
Transcript > ScanLineCard {
    margin-bottom: 2;
}

#main-display {
    width: 100%;
    height: 1fr;
    background: #060a14;
    color: #e9e9e9;
    scrollbar-size: 0 0;
    padding: 1 2;
}

/* ── Unified diff view ───────────────────────────────── */
UnifiedDiffView {
    width: 100%;
    border-top: solid #1b233a;
    background: #060a14;
    scrollbar-size-vertical: 1;
    scrollbar-size-horizontal: 0;
    scrollbar-color: #334155 #060a14;
    scrollbar-color-hover: #475569 #060a14;
    scrollbar-color-active: #64748b #060a14;
}

UnifiedDiffView.-compact {
    height: auto;
    overflow-y: hidden;
}

UnifiedDiffView.-scrollable {
    height: 10;
    overflow-y: auto;
}

UnifiedDiffView.-detail {
    height: 1fr;
    overflow-y: auto;
    border-top: none;
}

UnifiedDiffView .diff-truncated {
    color: #969aad;
    background: #0a1224;
}

UnifiedDiffRow .diff-gutter {
    color: #5a6478;
}

UnifiedDiffRow .diff-gutter.add {
    color: #6f9f82;
    background: #0a1410;
}

UnifiedDiffRow .diff-gutter.rem {
    color: #b87a7a;
    background: #120c0c;
}

UnifiedDiffRow .diff-code.ctx {
    color: #c8ceda;
}

UnifiedDiffRow .diff-code.add {
    background: #0a1410;
}

UnifiedDiffRow .diff-code.rem {
    background: #120c0c;
}

UnifiedDiffRow .diff-code.hdr {
    color: #969aad;
    background: transparent;
}

UnifiedDiffRow .diff-sign {
    color: #5a6478;
}

UnifiedDiffRow .diff-sign.add {
    color: #54efae;
    background: #0a1410;
}

UnifiedDiffRow .diff-sign.rem {
    color: #fd8383;
    background: #120c0c;
}

CollapsibleSection {
    transition: background 150ms, border-left 150ms;
    border-left: transparent;
    padding: 0 1;
}

CollapsibleSection:hover {
    background: #0a1122;
}

CollapsibleSection:focus {
    background: #0d162a;
    border-left: solid #5eead4;
}

.turn-summary {
    width: 100%;
    height: 1;
    padding: 0 1;
    background: #071b21;
    color: #5eead4;
    margin-bottom: 1;
}

/* ── Info Sidebar ──────────────────────────────────── */
InfoSidebar {
    background: #07101d;
    padding: 1 1;
    scrollbar-color: #64748b #0f172a;
    scrollbar-color-hover: #94a3b8 #0f172a;
    scrollbar-color-active: #cbd5e1 #0f172a;
    scrollbar-size: 0 1;
    overflow-y: auto;
    overflow-x: hidden;
}

SidebarRow {
    padding: 0 1;
    margin: 0 0 1 0;
    background: transparent;
    transition: background 150ms, color 150ms;
    width: 100%;
    height: auto;
    text-style: none;
}

CollapsibleSection .section-icon {
    text-style: none;
}

CollapsibleSection .collapsible-header.expanded {
    color: #c8d4e8;
    text-style: none;
}

SidebarRow:hover {
    background: #101c36;
    color: #e9e9e9;
}

SidebarRow:focus {
    background: #0e1a30;
    color: #e9eefc;
    border-left: solid #5eead4;
}

SidebarRow.-highlight {
    background: #132a45;
    border-left: solid #c792ea;
}

SidebarRow.-active-task {
    background: #0c1828;
    border-left: solid #5eead4;
}

SidebarRow.-read-only {
    color: #969aad;
}

SidebarRow.-read-only:hover {
    background: transparent;
    color: #969aad;
}

SidebarManageButton {
    dock: right;
    width: auto;
    height: 1;
    min-height: 1;
    min-width: 0;
    padding: 0 1;
    margin: 0 0 0 1;
    content-align: center middle;
    text-style: none;
    color: #6f83aa;
    background: transparent;
    border: none;
}

SidebarManageButton:hover {
    color: #91abec;
    background: #101c36;
}

SidebarManageButton:focus {
    color: #c8d4e8;
    background: #0e1a30;
}

SidebarManageButton.-mcp {
    color: #b89a6a;
    background: #1a1610;
}

SidebarManageButton.-mcp:hover,
SidebarManageButton.-mcp:focus {
    color: #eacb8a;
    background: #252015;
}

SidebarManageButton.-skill {
    color: #a88fd4;
    background: #181024;
}

SidebarManageButton.-skill:hover,
SidebarManageButton.-skill:focus {
    color: #c792ea;
    background: #221830;
}

GrintaManageMCPDialog > #dialog-container,
GrintaManageSkillsDialog > #dialog-container {
    width: 88;
    min-width: 88;
    max-width: 96%;
}

GrintaManageMCPDialog #dialog-buttons,
GrintaManageSkillsDialog #dialog-buttons {
    width: 100%;
    align-horizontal: left;
}

GrintaManageMCPDialog #dialog-buttons Button,
GrintaManageSkillsDialog #dialog-buttons Button {
    height: 1;
    min-height: 1;
    min-width: 8;
    width: auto;
    padding: 0 2;
    margin-left: 0;
    margin-right: 1;
}

/* ── Command Suggestions ────────────────────────────── */
#suggestions-list {
    width: 100%;
    max-height: 14;
    height: auto;
    background: #07101d;
    border-top: solid #26324f;
    border-bottom: solid #26324f;
    border-left: heavy #5eead4;
    padding: 1 0;
    margin: 0;
    scrollbar-size-vertical: 1;
    scrollbar-size-horizontal: 0;
    scrollbar-color: #64748b #0f172a;
    scrollbar-color-hover: #94a3b8 #0f172a;
    scrollbar-color-active: #cbd5e1 #0f172a;
}

#suggestions-list.-hidden {
    display: none;
}

#suggestions-list > ListItem {
    height: auto;
    min-height: 2;
    padding: 0;
    margin: 0 1;
    background: transparent;
    border: none;
}

#suggestions-list > ListItem:hover,
#suggestions-list > ListItem:focus,
#suggestions-list > ListItem.-highlighted {
    background: #101c36;
    border-left: solid #5eead4;
}

#suggestions-list CommandListRow {
    padding: 0 1;
}

#suggestions-list > ListItem.-highlighted CommandListRow {
    background: transparent;
}

#suggestions-list > ListItem.-highlighted CommandListRow .cmd-name {
    color: #e9e9e9;
}

#suggestions-list > ListItem.-highlighted CommandListRow .cmd-detail {
    color: #c8d4e8;
}

/* ── Welcome Widget ─────────────────────────────────── */
WelcomeWidget {
    width: 100%;
    height: auto;
    padding: 2 3 2 3;
    margin: 2 1 0 0;
    background: #08101d;
    border: round #1b233a;
    border-left: heavy #5eead4;
}

#welcome-header {
    height: auto;
    color: #c8d4e8;
    text-style: none;
}

#welcome-subheader {
    height: auto;
    color: #6f83aa;
    margin: 0 0 2 0;
}

.welcome-item {
    height: auto;
    min-height: 2;
    padding: 0 1 0 2;
    margin: 0 0 1 0;
}

.welcome-item:hover {
    background: #101c36;
    border-left: solid #5eead4;
}

#welcome-logo {
    color: #3a4a6a;
    margin: 0 0 1 0;
}

#welcome-slogan-row {
    height: auto;
    width: 100%;
    margin: 0 0 1 0;
}

#slogan-text {
    width: auto;
    height: auto;
    color: #54597b;
}

#slogan-tagline {
    width: auto;
    height: auto;
    color: #ff007f;
    text-style: bold blink;
}

#welcome-slogan {
    height: auto;
    color: #c8d4e8;
    text-style: none;
}

#welcome-tagline {
    height: auto;
    color: #6f83aa;
    text-style: italic;
    margin: 0 0 1 0;
}

#welcome-instruction {
    height: auto;
    color: #6f83aa;
    margin: 0 0 2 0;
}

/* ── InputBar ──────────────────────────────────────── */
InputBar {
    height: 6;
    background: #08101d;
    border: solid #1f6d64;
    padding: 0;
    layout: vertical;
}

InputBar.-blurred {
    border: solid #15233c;
}

#input-hint {
    height: 1;
    padding: 0 2;
    color: #6a7a9a;
    text-style: italic;
}

#input-hint.-image-attached {
    color: #5eead4;
    text-style: bold;
}

#input-row {
    layout: horizontal;
    height: 1fr;
}

InputBar TextArea {
    background: #0b1628;
    color: #c8d4e8;
    border: none;
    padding: 0 2;
    width: 1fr;
    height: 1fr;
    overflow-y: auto;
    transition: background 150ms;
}

InputBar TextArea:focus {
    background: #12223a;
}

#spinner {
    width: 3;
    height: 1fr;
    content-align: center middle;
    color: #91abec;
    margin-right: 0;
}

#spinner.-hidden {
    display: none;
}

/* ── HUD Bar ────────────────────────────────────────── */
HUD,
#hud-bar {
    height: auto;
    background: #0a1525;
    color: #969aad;
    padding: 0 2;
    padding-bottom: 1;
}

#hud-line-1 {
    height: 1;
    text-style: none;
    margin-right: 3;
}

#hud-line-1-row {
    height: 1;
    layout: horizontal;
    align-vertical: middle;
    margin: 0;
    padding: 0;
}

#hud-label-model {
    height: 1;
    padding: 0 1 0 0;
    margin: 0 0 0 2;
}

#hud-label-reasoning {
    height: 1;
    padding: 0 1 0 0;
    margin: 0 0 0 3;
}

#hud-model-name {
    height: 1;
    margin-right: 1;
    color: #c8d4e8;
}

#hud-line-2-ws {
    height: 1;
    text-align: left;
    color: #8f9fc1;
    margin-right: 3;
}

#hud-line-1-spacer,
#hud-line-2-spacer {
    width: 1fr;
    height: 1;
}

#hud-line-1-help {
    height: 1;
    color: #8f9fc1;
    text-align: right;
}

#hud-hint-interrupt {
    height: 1;
    padding: 0 1 0 0;
    margin: 0 2 0 0;
    color: #c8d4e8;
    text-align: right;
}

#hud-line-2 {
    height: 1;
    color: #8f9fc1;
    text-align: right;
}

#hud-line-2-row {
    height: 2;
    layout: horizontal;
    align-vertical: middle;
    margin: 0;
    padding: 0;
}

#hud-label-autonomy,
#hud-label-mode {
    height: 1;
    padding: 0 1 0 0;
    margin: 0;
}

#hud-label-mode {
    margin-left: 2;
}

#hud-label-autonomy {
    margin-left: 3;
}

#hud-reasoning {
    width: 18;
    margin-right: 1;
    background: transparent;
    border: none;
    padding: 0;
    min-height: 1;
    height: 1;
}

#hud-reasoning SelectCurrent {
    background: #8a6a2a;
    color: #060a14;
    border: none;
    padding: 0 2;
    height: 1;
    min-height: 1;
}

#hud-reasoning SelectCurrent:focus {
    background: #b8923a;
}

#hud-reasoning SelectCurrent #label {
    color: #060a14;
    padding: 0;
    margin: 0;
    height: 1;
    text-style: none;
}

#hud-reasoning SelectCurrent .arrow {
    height: 1;
    padding: 0;
    margin: 0;
    color: #060a14;
}

#hud-reasoning SelectOverlay {
    background: #0d1a30;
    border: solid #6a5020;
    min-width: 18;
}

#hud-reasoning SelectOverlay .option-list--option {
    background: #0d1a30;
    color: #8f9fc1;
    padding: 0 2;
    margin: 0;
}

#hud-reasoning SelectOverlay .option-list--option:hover {
    background: #1a3055;
}

#hud-reasoning SelectOverlay .option-list--option-highlighted {
    background: #1a3055;
    color: #e9eefc;
}

#hud-autonomy {
    width: 20;
    margin-right: 1;
    background: transparent;
    border: none;
    padding: 0;
    min-height: 1;
    height: 1;
}

#hud-autonomy SelectCurrent {
    background: #3a5a8c;
    color: #060a14;
    border: none;
    padding: 0 2;
    height: 1;
    min-height: 1;
}

#hud-autonomy SelectCurrent:focus {
    background: #5a8acc;
}

#hud-autonomy SelectCurrent #label {
    color: #060a14;
    padding: 0;
    margin: 0;
    height: 1;
    text-style: none;
}

#hud-autonomy SelectCurrent .arrow {
    height: 1;
    padding: 0;
    margin: 0;
    color: #060a14;
}

#hud-autonomy SelectOverlay {
    background: #0d1a30;
    border: solid #2a4a7a;
    min-width: 20;
}

#hud-autonomy SelectOverlay .option-list--option {
    background: #0d1a30;
    color: #8f9fc1;
    padding: 0 2;
    margin: 0;
}

#hud-autonomy SelectOverlay .option-list--option:hover {
    background: #1a3055;
}

#hud-autonomy SelectOverlay .option-list--option-highlighted {
    background: #1a3055;
    color: #e9eefc;
}

#hud-mode {
    width: 14;
    margin-right: 1;
    background: transparent;
    border: none;
    padding: 0;
    min-height: 1;
    height: 1;
}

#hud-mode SelectCurrent {
    background: #1f6d64;
    color: #060a14;
    border: none;
    padding: 0 2;
    height: 1;
    min-height: 1;
}

#hud-mode SelectCurrent:focus {
    background: #2a9d8f;
}

#hud-mode SelectCurrent #label {
    color: #060a14;
    padding: 0;
    margin: 0;
    height: 1;
    text-style: none;
}

#hud-mode SelectCurrent .arrow {
    height: 1;
    padding: 0;
    margin: 0;
    color: #060a14;
}

#hud-mode SelectOverlay {
    background: #0d1a30;
    border: solid #5a3a2a;
    min-width: 14;
}

#hud-mode SelectOverlay .option-list--option {
    background: #0d1a30;
    color: #8f9fc1;
    padding: 0 2;
    margin: 0;
}

#hud-mode SelectOverlay .option-list--option:hover {
    background: #1a3055;
}

#hud-mode SelectOverlay .option-list--option-highlighted {
    background: #1a3055;
    color: #e9eefc;
}

/* ── Textual Generic Controls Design System ──────────────── */

/* Inputs & Textareas */
Input {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
    transition: background 150ms, border-left 150ms;
}

Input:focus {
    background: #12223a;
    border-left: solid #91abec;
}

/* Checkbox */
Checkbox {
    background: transparent;
    color: #cbd5e1;
}

Checkbox:hover {
    color: #ffffff;
}

Checkbox > .checkbox--box {
    background: #0f1c30;
    color: #91abec;
}

Checkbox.-on > .checkbox--box {
    background: #15274d;
    color: #5eead4;
}

/* Select */
Select {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
}

Select:focus {
    border-left: solid #91abec;
}

/* Buttons */
Button {
    background: #101c36;
    color: #e9e9e9;
    border: none;
    padding: 1 4;
    min-width: 16;
    height: 3;
    transition: background 150ms, color 150ms;
}

Button:hover {
    background: #15274d;
    color: #ffffff;
}

Button:focus {
    background: #1e3a70;
    color: #ffffff;
    border-left: solid #91abec;
}

Button.-active {
    background: #2563eb;
    color: #ffffff;
}

Button.primary {
    background: #1e3a70;
    color: #ffffff;
}

Button.primary:hover {
    background: #2563eb;
    color: #ffffff;
}

Button.primary:focus {
    border-left: solid #5eead4;
}

Button.-error {
    background: #451a1a;
    color: #fd8383;
}

Button.-error:hover {
    background: #f05757;
    color: #ffffff;
}

Button.-error:focus {
    border-left: solid #fd8383;
}

/* Data Table */
DataTable {
    background: #080c18;
    color: #cbd5e1;
    scrollbar-color: #33405d #161e31;
}

DataTable > .datatable--header {
    background: #0f1c30;
    color: #ffffff;
    text-style: none;
}

DataTable > .datatable--row-hover {
    background: #101c36;
}

DataTable > .datatable--row-selected {
    background: #15274d;
    color: #ffffff;
}

/* ── Dialog-specific overrides ──────────────────────── */
GrintaSettingsDialog #settings-panel,
GrintaSessionsDialog #sessions-panel {
    margin-bottom: 0;
}

/* Dialog selects + dropdown lists — match command suggestions chrome */
GrintaSettingsDialog Select,
GrintaSessionsDialog Select {
    background: #0a1323;
    border: none;
    color: #c8d4e8;
    height: 1;
    min-height: 1;
    padding: 0;
}

GrintaSettingsDialog Select:focus,
GrintaSessionsDialog Select:focus {
    border-left: solid #91abec;
}

GrintaSettingsDialog SelectCurrent,
GrintaSessionsDialog SelectCurrent {
    background: #0a1323;
    color: #c8d4e8;
    border: none;
    padding: 0 1;
    height: 1;
    min-height: 1;
}

GrintaSettingsDialog SelectCurrent:focus,
GrintaSessionsDialog SelectCurrent:focus {
    background: #12223a;
    border-left: solid #91abec;
}

GrintaSettingsDialog SelectCurrent #label,
GrintaSessionsDialog SelectCurrent #label {
    color: #c8d4e8;
    padding: 0;
    margin: 0;
    height: 1;
}

GrintaSettingsDialog SelectCurrent .arrow,
GrintaSessionsDialog SelectCurrent .arrow {
    height: 1;
    padding: 0;
    margin: 0;
    color: #8f9fc1;
}

GrintaSettingsDialog SelectOverlay,
GrintaSessionsDialog SelectOverlay {
    background: #07101d;
    border-top: solid #26324f;
    border-bottom: solid #26324f;
    border-left: heavy #5eead4;
    border-right: none;
    padding: 0;
    scrollbar-size-vertical: 1;
    scrollbar-color: #64748b #0f172a;
    scrollbar-color-hover: #94a3b8 #0f172a;
    scrollbar-color-active: #cbd5e1 #0f172a;
}

GrintaSettingsDialog SelectOverlay .option-list--option,
GrintaSessionsDialog SelectOverlay .option-list--option {
    background: transparent;
    color: #c8d4e8;
    padding: 0 1;
    margin: 0 1;
    height: auto;
    min-height: 1;
}

GrintaSettingsDialog SelectOverlay .option-list--option:hover,
GrintaSessionsDialog SelectOverlay .option-list--option:hover,
GrintaSettingsDialog SelectOverlay .option-list--option-highlighted,
GrintaSessionsDialog SelectOverlay .option-list--option-highlighted {
    background: #101c36;
    color: #e9e9e9;
    border-left: solid #5eead4;
}

GrintaSettingsDialog Input,
GrintaSessionsDialog Input {
    height: 1;
    min-height: 1;
    border: none;
    background: #0a1323;
    color: #c8d4e8;
    padding: 0 1;
}

GrintaSettingsDialog Input:focus,
GrintaSessionsDialog Input:focus {
    background: #12223a;
    border-left: solid #91abec;
}

GrintaSessionsDialog #sessions-table {
    background: #07101d;
    color: #c8d4e8;
    border: none;
    scrollbar-color: #64748b #0f172a;
    scrollbar-color-hover: #94a3b8 #0f172a;
    scrollbar-color-active: #cbd5e1 #0f172a;
}

GrintaSessionsDialog #sessions-table > .datatable--header {
    background: #08101d;
    color: #8f9fc1;
    text-style: bold;
    border-bottom: solid #26324f;
}

GrintaSessionsDialog #sessions-table > .datatable--cursor {
    background: #101c36;
    color: #e9e9e9;
}

GrintaSessionsDialog #sessions-table > .datatable--row-even,
GrintaSessionsDialog #sessions-table > .datatable--row-odd {
    background: transparent;
}

GrintaSessionsDialog #sessions-table > .datatable--row-hover {
    background: #101c36;
    color: #e9e9e9;
}

GrintaSessionsDialog #sessions-table > .datatable--row-selected {
    background: #101c36;
    color: #e9e9e9;
    border-left: solid #5eead4;
}

GrintaSessionsDialog #sessions-preview {
    background: #07101d;
    border-top: solid #26324f;
    color: #c8d4e8;
}

#settings-current-key {
    color: #8f9fc1;
}

#settings-model-meta {
    color: #8f9fc1;
}

GrintaAddSkillDialog TextArea {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
    padding: 0 1;
    width: 100%;
    height: 10;
    margin-bottom: 1;
    transition: background 150ms, border-left 150ms;
}

GrintaAddSkillDialog TextArea:focus {
    background: #12223a;
    border-left: solid #91abec;
}

#help-body {
    height: auto;
    max-height: 28;
    overflow-y: auto;
    color: #cbd5e1;
    padding: 0;
    background: transparent;
    border: none;
    scrollbar-size-vertical: 1;
    scrollbar-size-horizontal: 0;
    scrollbar-color: #64748b #0f172a;
    scrollbar-color-hover: #94a3b8 #0f172a;
    scrollbar-color-active: #cbd5e1 #0f172a;
}

#dialog-subtitle {
    color: #6f83aa;
    height: auto;
    margin-bottom: 1;
}

CommandListPanel {
    margin-bottom: 1;
}

/* ── Toast notifications ──────────────────────────── */
Toast {
    background: #060a14;
    border-right: wide #060a14;
}

Toast.-success { border-left: wide #5bd088; }
Toast.-error { border-left: wide #f05757; }

/* ── Transcript Messages ────────────────────────────── */
UserMessage {
    width: 100%;
    height: auto;
    margin: 1 0 2 0;
    padding: 1 2 2 2;
    background: #151d32;
    border: transparent;
    border-right: wide #91abec;
    color: #f2f6ff;
}

AgentMessage {
    width: 100%;
    height: auto;
    margin: 0 0 1 0;
    padding: 0;
    border: none;
    background: transparent;
    color: #c8d4e8;
}

LiveResponse {
    width: 100%;
    height: auto;
    margin: 0 0 1 0;
    padding: 0;
    border: none;
    background: transparent;
}

LiveResponse > #live-content {
    width: 100%;
    height: auto;
    color: #b8c4d8;
}

LiveResponse.-streaming > #live-content {
    color: #d5dee8;
}

ThinkingIndicator {
    width: 100%;
    height: auto;
    margin: 0 0 2 0;
    padding: 1 1 1 2;
}

ErrorBlock {
    width: 100%;
    height: auto;
    margin: 0 0 2 0;
    padding: 0 1 0 2;
}

TranscriptNotice {
    width: 100%;
    height: auto;
    margin: 0 0 2 0;
    padding: 0 1;
    background: #12161f;
    border: none;
    color: #7a8299;
}

/* ── Utility ───────────────────────────────────────── */
.hidden { display: none; }
