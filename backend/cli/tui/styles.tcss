/* Grinta TUI — "Deep System Instrumentation" Theme
 * NASA mission-control aesthetic.
 * Deep Navy (#0a0e14) background, Teal (#5fb3b3) accents.
 */

Screen {
    background: #0a0e14;
    color: #d8dee9;
}

/* ── Header ────────────────────────────────────────── */

GrintaHeader {
    height: 2;
    background: #0f151c;
    border-bottom: solid #1b2b34;
    dock: top;
    padding: 0 2;
}

/* ── Transcript ────────────────────────────────────── */

Transcript {
    background: #0a0e14;
    scrollbar-color: #2b3b44 #0a0e14;
    scrollbar-size: 2 8;
}

/* ── Input area ────────────────────────────────────── */

InputArea {
    height: 3;
    background: #0f151c;
    border-top: solid #1b2b34;
    dock: bottom;
    padding: 0 4;
}

InputArea Static {
    color: #5fb3b3;
    text-style: bold;
    padding: 0 4;
}

InputArea TextArea {
    background: #0a0e14;
    color: #d8dee9;
    border: solid #1b2b34;
    padding: 2 8;
}

InputArea TextArea:focus {
    border: solid #5fb3b3;
}

InputArea.processing TextArea {
    border: solid #5fb3b3;
}

/* ── Footer ────────────────────────────────────────── */

GrintaFooter {
    height: 1;
    background: #0f151c;
    color: #65737e;
    dock: bottom;
    text-align: center;
}

GrintaFooter.hidden {
    display: none;
}

/* ── Confirmation dialog ───────────────────────────── */

GrintaConfirmDialog {
    background: #0f151c;
    border: solid #1b2b34;
    padding: 2 4;
    width: 60;
    align: center top;
}

GrintaConfirmDialog .title {
    color: #5fb3b3;
    text-style: bold;
    margin-bottom: 1;
}

GrintaConfirmDialog .body {
    color: #d8dee9;
    margin-bottom: 2;
}

GrintaConfirmDialog Button {
    background: #0f151c;
    color: #d8dee9;
    border: solid #1b2b34;
    margin: 0 1;
}

GrintaConfirmDialog Button:hover {
    background: #5fb3b3;
    color: #0a0e14;
    border: solid #5fb3b3;
}