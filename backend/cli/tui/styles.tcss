/* Grinta TUI — Mission Control layout */

Screen {
    background: #060a14;
    color: #e9e9e9;
}


/* ── Layout Containers ──────────────────────────────── */
#app-layout {
    layout: horizontal;
    height: 100%;
}

#left-column {
    width: 75%;
    height: 100%;
    background: #060a14;
}

#sidebar {
    width: 25%;
    height: 100%;
    layout: vertical;
    background: #080c18;
    border-left: solid #1e293b;
}

#sidebar.-hidden {
    display: none;
}

#sidebar-container {
    height: 1fr;
}

/* ── Transcript ────────────────────────────────────── */
Transcript {
    background: #060a14;
    scrollbar-color: #33405d #161e31;
    scrollbar-color-hover: #404f71 #161e31;
    scrollbar-color-active: #4f608a #161e31;
    scrollbar-size: 1 0;
    padding: 1 2 2 2;
    height: 1fr;
    layout: vertical;
    overflow-x: hidden;
}

#main-display {
    width: 100%;
    height: 1fr;
    background: #060a14;
    color: #e9e9e9;
    scrollbar-color: #33405d #161e31;
    scrollbar-color-hover: #404f71 #161e31;
    scrollbar-color-active: #4f608a #161e31;
    scrollbar-size: 1 0;
    padding: 1 2;
}

/* ── Interactive Components Focus & Hover ──────────── */
ActivityCard {
    transition: background 150ms, border 150ms;
}

ActivityCard.-expanded {
    transition: background 150ms, border 150ms;
    border: round #1b233a;
    background: #08101d;
    padding: 0;
    margin: 0 0 1 0;
}

ActivityCard.-expanded:hover {
    background: #0a1323;
    border: round #26365b;
}

ActivityCard.-expanded:focus {
    background: #0d162a;
    border: round #4a5f99;
}

ActivityCard.-expanded.category-shell,
ActivityCard.-expanded.category-terminal {
    border: round #24385c;
    background: #050913;
}

ActivityCard .card-collapsed-row {
    color: #c8d4e8;
}

ActivityCard .card-collapsed-row:hover {
    background: #0a1323;
}

ActivityCard .card-expanded-body {
    border: none;
}

ActivityCard .card-meta-row {
    color: #54597b;
}

CollapsibleSection {
    transition: background 150ms, border-left 150ms;
    border-left: transparent;
    padding: 0 1;
}

CollapsibleSection:hover {
    background: #0a1122;
}

CollapsibleSection:focus {
    background: #0d162a;
    border-left: solid #5eead4;
}

.turn-summary {
    width: 100%;
    height: 1;
    padding: 0 1;
    background: #071b21;
    color: #5eead4;
    margin-bottom: 1;
}

/* ── Info Sidebar ──────────────────────────────────── */
InfoSidebar {
    background: #080c18;
    padding: 1 1;
    scrollbar-size: 0 0;
    overflow-y: auto;
    overflow-x: hidden;
}

SidebarRow {
    padding: 0 1;
    margin: 0 0 1 0;
    background: transparent;
    transition: background 150ms, color 150ms;
    width: 100%;
    height: auto;
}

SidebarRow:hover {
    background: #101c36;
    color: #e9e9e9;
}

SidebarRow:focus {
    background: #0e1a30;
    color: #e9eefc;
    border-left: solid #5eead4;
}

/* ── Command Suggestions ────────────────────────────── */
#suggestions-list {
    width: 100%;
    max-height: 6;
    height: auto;
    background: #0d1a30;
    border-top: solid #15233c;
    border-bottom: solid #15233c;
    padding: 0;
    margin: 0;
}

#suggestions-list.-hidden {
    display: none;
}

#suggestions-list > ListItem {
    height: 1;
    padding: 0 2;
    margin: 0;
    background: #0a1525;
    color: #8f9fc1;
}

#suggestions-list > ListItem:hover {
    background: #1a3055;
}

#suggestions-list > ListItem:focus {
    background: #1a3055;
}

#suggestions-list > ListItem.-highlighted {
    background: #1a3055;
}

/* ── Welcome Widget ─────────────────────────────────── */
WelcomeWidget {
    width: 100%;
    height: auto;
    padding: 3 4 2 4;
    margin: 2 1 0 0;
    background: #07101d;
    border-left: heavy #32527a;
}

#welcome-header {
    height: 1;
    color: #c8d4e8;
    text-style: bold;
}

#welcome-subheader {
    height: 1;
    color: #6f83aa;
    margin: 0 0 2 0;
}

.welcome-item {
    height: 1;
    padding: 0 0 0 2;
    margin: 0 0 1 0;
}

.welcome-item:hover {
    background: #0f1c31;
}

/* ── InputBar ──────────────────────────────────────── */
InputBar {
    height: 6;
    background: #08101d;
    border: solid #1f6d64;
    padding: 0;
    layout: vertical;
}

InputBar.-blurred {
    border: solid #15233c;
}

#input-hint {
    height: 1;
    padding: 0 2;
    color: #6a7a9a;
    text-style: italic;
}

#input-row {
    layout: horizontal;
    height: 1fr;
}

InputBar TextArea {
    background: #0b1628;
    color: #c8d4e8;
    border: none;
    padding: 0 2;
    width: 1fr;
    height: 1fr;
    overflow-y: auto;
    transition: background 150ms;
}

InputBar TextArea:focus {
    background: #12223a;
}

#spinner {
    width: 3;
    height: 1fr;
    content-align: center middle;
    color: #91abec;
    margin-right: 0;
}

#spinner.-hidden {
    display: none;
}

/* ── HUD Bar ────────────────────────────────────────── */
HUD,
#hud-bar {
    height: auto;
    background: #0a1525;
    color: #969aad;
    padding: 1 2;
    border-top: solid #15233c;
}

#hud-line-1 {
    height: 1;
    text-style: bold;
}

#hud-line-2 {
    width: 1fr;
    height: 1;
    color: #8f9fc1;
}

#hud-line-2-row {
    height: 2;
    layout: horizontal;
    align-vertical: middle;
    margin: 0;
    border-top: solid #15233c;
    padding: 0;
}

#hud-label-autonomy,
#hud-label-mode {
    height: 1;
    padding: 0 1 0 0;
    margin: 0;
}

#hud-autonomy {
    width: 20;
    margin-right: 1;
    background: transparent;
    border: none;
    padding: 0;
    min-height: 1;
    height: 1;
}

#hud-autonomy SelectCurrent {
    background: #3a5a8c;
    color: #060a14;
    border: none;
    padding: 0 2;
    height: 1;
    min-height: 1;
}

#hud-autonomy SelectCurrent:focus {
    background: #5a8acc;
}

#hud-autonomy SelectCurrent #label {
    color: #060a14;
    padding: 0;
    margin: 0;
    height: 1;
    text-style: bold;
}

#hud-autonomy SelectCurrent .arrow {
    height: 1;
    padding: 0;
    margin: 0;
    color: #060a14;
}

#hud-autonomy SelectOverlay {
    background: #0d1a30;
    border: solid #2a4a7a;
}

#hud-autonomy SelectOverlay .option-list--option {
    background: #0d1a30;
    color: #8f9fc1;
    padding: 0 2;
    margin: 0;
}

#hud-autonomy SelectOverlay .option-list--option:hover {
    background: #1a3055;
}

#hud-autonomy SelectOverlay .option-list--option-highlighted {
    background: #1a3055;
    color: #e9eefc;
}

#hud-mode {
    width: 14;
    margin-right: 1;
    background: transparent;
    border: none;
    padding: 0;
    min-height: 1;
    height: 1;
}

#hud-mode SelectCurrent {
    background: #1f6d64;
    color: #060a14;
    border: none;
    padding: 0 2;
    height: 1;
    min-height: 1;
}

#hud-mode SelectCurrent:focus {
    background: #2a9d8f;
}

#hud-mode SelectCurrent #label {
    color: #060a14;
    padding: 0;
    margin: 0;
    height: 1;
    text-style: bold;
}

#hud-mode SelectCurrent .arrow {
    height: 1;
    padding: 0;
    margin: 0;
    color: #060a14;
}

#hud-mode SelectOverlay {
    background: #0d1a30;
    border: solid #5a3a2a;
}

#hud-mode SelectOverlay .option-list--option {
    background: #0d1a30;
    color: #8f9fc1;
    padding: 0 2;
    margin: 0;
}

#hud-mode SelectOverlay .option-list--option:hover {
    background: #1a3055;
}

#hud-mode SelectOverlay .option-list--option-highlighted {
    background: #1a3055;
    color: #e9eefc;
}

/* ── Textual Generic Controls Design System ──────────────── */

/* Inputs & Textareas */
Input {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
    transition: background 150ms, border-left 150ms;
}

Input:focus {
    background: #12223a;
    border-left: solid #91abec;
}

/* Checkbox */
Checkbox {
    background: transparent;
    color: #cbd5e1;
}

Checkbox:hover {
    color: #ffffff;
}

Checkbox > .checkbox--box {
    background: #0f1c30;
    color: #91abec;
}

Checkbox.-on > .checkbox--box {
    background: #15274d;
    color: #5eead4;
}

/* Select */
Select {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
}

Select:focus {
    border-left: solid #91abec;
}

/* Buttons */
Button {
    background: #101c36;
    color: #e9e9e9;
    border: none;
    padding: 1 4;
    min-width: 16;
    height: 3;
    transition: background 150ms, color 150ms;
}

Button:hover {
    background: #15274d;
    color: #ffffff;
}

Button:focus {
    background: #1e3a70;
    color: #ffffff;
    border-left: solid #91abec;
}

Button.-active {
    background: #2563eb;
    color: #ffffff;
}

Button.primary {
    background: #1e3a70;
    color: #ffffff;
}

Button.primary:hover {
    background: #2563eb;
    color: #ffffff;
}

Button.primary:focus {
    border-left: solid #5eead4;
}

Button.-error {
    background: #451a1a;
    color: #fd8383;
}

Button.-error:hover {
    background: #f05757;
    color: #ffffff;
}

Button.-error:focus {
    border-left: solid #fd8383;
}

/* Data Table */
DataTable {
    background: #080c18;
    color: #cbd5e1;
    scrollbar-color: #33405d #161e31;
}

DataTable > .datatable--header {
    background: #0f1c30;
    color: #ffffff;
    text-style: bold;
}

DataTable > .datatable--row-hover {
    background: #101c36;
}

DataTable > .datatable--row-selected {
    background: #15274d;
    color: #ffffff;
}

/* ── Dialog-specific overrides ──────────────────────── */
#settings-current-key {
    color: #8f9fc1;
    margin-top: 1;
}

#settings-model,
#settings-api-key,
#settings-budget {
    margin-bottom: 1;
}

GrintaAddSkillDialog TextArea,
GrintaSettingsDialog TextArea {
    background: #0f1c30;
    color: #c8d4e8;
    border: none;
    padding: 0 1;
    width: 100%;
    height: 10;
    margin-bottom: 1;
    transition: background 150ms, border-left 150ms;
}

GrintaAddSkillDialog TextArea:focus,
GrintaSettingsDialog TextArea:focus {
    background: #12223a;
    border-left: solid #91abec;
}

#sessions-filters {
    height: auto;
    margin-bottom: 1;
}

#sessions-search {
    width: 1fr;
}

#sessions-sort {
    width: 18;
    margin-left: 1;
}

#sessions-limit {
    width: 10;
    margin-left: 1;
}

#sessions-refresh {
    margin-left: 1;
}

#sessions-table {
    height: 12;
    margin-bottom: 1;
    border: none;
}

#sessions-preview {
    height: auto;
    max-height: 10;
    border: round #1e293b;
    padding: 1 2;
    background: #060a14;
    color: #cbd5e1;
}

#dialog-feedback {
    color: #8f9fc1;
    margin-top: 1;
}

#help-body {
    height: auto;
    color: #cbd5e1;
    border: round #1e293b;
    background: #060a14;
    padding: 1 2;
}

/* ── Toast notifications ──────────────────────────── */
Toast {
    background: #060a14;
    border-right: wide #060a14;
}

Toast.-success { border-left: wide #5bd088; }
Toast.-error { border-left: wide #f05757; }

/* ── Transcript Messages ────────────────────────────── */
UserMessage {
    width: 100%;
    height: auto;
    margin: 1 0;
    padding: 1 2;
    background: #091522;
    border: round #18485a;
    color: #f8fafc;
}

AgentMessage {
    width: 100%;
    height: auto;
    margin: 1 0;
    padding: 1 2;
    background: #080c16;
    border: none;
    color: #cbd5e1;
}

/* ── Scroll badge ──────────────────────────────────── */
#scroll-badge {
    dock: bottom;
    width: 100%;
    height: 1;
    background: #0d1a30;
    color: #5eead4;
    text-align: center;
    text-style: bold;
}

#scroll-badge.-hidden {
    display: none;
}

/* ── Utility ───────────────────────────────────────── */
.hidden { display: none; }
