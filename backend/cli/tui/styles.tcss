/* Grinta TUI — Deep Navy Theme
 * Modern, premium dark aesthetic with cyan accents.
 */

Screen {
    background: #070b14;
    color: #e2e8f0;
}

/* ── Header ────────────────────────────────────────── */

GrintaHeader {
    height: 2;
    background: #0d1526;
    border-bottom: solid #1e3a5f;
    dock: top;
    padding: 0 2;
}

/* ── Transcript ────────────────────────────────────── */

Transcript {
    background: #070b14;
    scrollbar-color: #2d4a6f #070b14;
    scrollbar-size: 2 8;
}

/* ── Input area ────────────────────────────────────── */

InputArea {
    height: 3;
    background: #0d1526;
    border-top: solid #1e3a5f;
    dock: bottom;
    padding: 0 4;
}

InputArea Static {
    color: #00d4ff;
    text-style: bold;
    padding: 0 4;
}

InputArea TextArea {
    background: #070b14;
    color: #e2e8f0;
    border: solid #1e3a5f;
    padding: 2 8;
}

InputArea TextArea:focus {
    border: solid #00d4ff;
}

InputArea.processing TextArea {
    border: solid #00d4ff;
}

/* ── Footer ────────────────────────────────────────── */

GrintaFooter {
    height: 1;
    background: #0d1526;
    color: #64748b;
    dock: bottom;
    text-align: center;
}

GrintaFooter.hidden {
    display: none;
}

/* ── Confirmation dialog ───────────────────────────── */

GrintaConfirmDialog {
    background: #111d30;
    border: solid #2d4a6f;
    padding: 2 4;
    width: 60;
    align: center top;
}

GrintaConfirmDialog .title {
    color: #00d4ff;
    text-style: bold;
    margin-bottom: 1;
}

GrintaConfirmDialog .body {
    color: #e2e8f0;
    margin-bottom: 2;
}

GrintaConfirmDialog Button {
    background: #0d1526;
    color: #e2e8f0;
    border: solid #2d4a6f;
    margin: 0 1;
}

GrintaConfirmDialog Button:hover {
    background: #00d4ff;
    color: #070b14;
    border: solid #00d4ff;
}