{
  "profiles": {
    "openai_gpt5": {
      "strip_temperature": true,
      "strip_top_p": true,
      "use_max_completion_tokens": true,
      "supports_function_calling": true,
      "supports_parallel_tool_calls": true,
      "supports_reasoning_effort": true
    },
    "openai_o_series": {
      "strip_temperature": true,
      "strip_top_p": true,
      "strip_penalties": true,
      "supports_function_calling": true,
      "supports_parallel_tool_calls": true
    },
    "anthropic_claude4": {
      "supports_function_calling": true,
      "supports_parallel_tool_calls": true,
      "supports_reasoning_effort": true,
      "supports_prompt_cache": true
    },
    "gemini_pro": {
      "supports_function_calling": true,
      "supports_parallel_tool_calls": true,
      "supports_reasoning_effort": true
    },
    "gemini_flash": {
      "supports_function_calling": true,
      "supports_parallel_tool_calls": true,
      "supports_reasoning_effort": true
    },
    "provider_default": {
      "supports_function_calling": true,
      "supports_parallel_tool_calls": true
    },
    "conservative": {
      "supports_function_calling": true,
      "strip_reasoning_effort": true
    }
  },
  "provider_defaults": {
    "anthropic": "anthropic_claude4",
    "openai": "provider_default",
    "google": "gemini_pro",
    "groq": "provider_default",
    "mistral": "provider_default",
    "deepseek": "provider_default",
    "xai": "provider_default",
    "openrouter": "provider_default",
    "vercel": "provider_default",
    "ollama": "provider_default",
    "lm_studio": "provider_default",
    "vllm": "provider_default"
  },
  "family_patterns": [
    {"family": "openai_gpt5", "patterns": ["gpt-5*", "gpt-5.*", "*codex*"]},
    {"family": "openai_o_series", "patterns": ["o1*", "o3*", "o4*"]},
    {"family": "anthropic_claude4", "patterns": ["claude-*", "claude*"]},
    {"family": "gemini_flash", "patterns": ["*gemini*flash*", "*flash*"]},
    {"family": "gemini_pro", "patterns": ["*gemini*pro*", "gemini-*"]}
  ]
}
