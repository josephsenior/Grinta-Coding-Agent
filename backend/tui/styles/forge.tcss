/* ═══════════════════════════════════════════════════════════
   Forge TUI — Global Stylesheet
   Dark-professional theme designed for long coding sessions.
═══════════════════════════════════════════════════════════ */

/* ── Global ─────────────────────────────────────────────── */

Screen {
    background: black;
}

Header {
    background: #111111;
    color: $accent;
    height: 1;
    dock: top;
    text-style: bold;
}

Footer {
    background: #080808;
    color: #666666;
    height: 1;
}

/* ── Home Screen ─────────────────────────────────────────── */

#home-outer {
    height: 100%;
    padding: 0 2 1 2;
    background: black;
}

#home-header {
    height: 11;
    content-align: center middle;
    border-bottom: hkey #222222;
    padding: 1 0;
    margin-bottom: 1;
}

#home-logo {
    text-align: center;
    color: $accent;
    width: 100%;
    margin-bottom: 1;
    text-style: bold;
}

#home-title {
    display: none;
}

#home-subtitle {
    text-align: center;
    color: #888888;
    width: 100%;
    text-style: italic;
}

#home-fingerprint {
    text-align: center;
    color: $primary;
    width: 100%;
    margin-top: 1;
}

#home-stats {
    text-align: center;
    color: #444444;
    width: 100%;
}

#search-bar {
    height: 3;
    padding: 0;
    margin-bottom: 1;
}

#search-input {
    width: 1fr;
    border: tall #333333;
    background: #111111;
}

#search-input:focus {
    border: tall $accent;
}

#list-area {
    height: 1fr;
}

#conversation-list-view {
    height: 1fr;
    border: round #333333;
    background: #080808;
    scrollbar-color: #333333;
    scrollbar-color-hover: $accent;
}

#empty-state {
    height: 1fr;
    content-align: center middle;
    color: #555555;
    text-style: italic;
    border: round #333333;
    background: #080808;
}

#new-bar {
    height: 3;
    dock: bottom;
    padding: 0;
    margin-top: 1;
}

#new-input {
    width: 1fr;
    border: tall #333333;
    background: #111111;
}

#new-input:focus {
    border: tall $success 60%;
}

/* ── Conversation List Items ─────────────────────────────── */

.conversation-item {
    height: 3;
    padding: 0 1;
    border-bottom: hkey #111111;
}

.conversation-item:hover {
    background: #151515;
}

.conversation-item:focus-within {
    background: $accent 10%;
}

ConversationListItem {
    padding: 0;
}

ConversationListItem:hover {
    background: #151515;
}

ConversationListItem.-highlight {
    background: #1a1a1a;
    border-left: outer $accent;
}

.conversation-title {
    width: 1fr;
    text-style: bold;
    color: #eeeeee;
    padding: 0 1 0 0;
}

.conversation-meta {
    color: #666666;
    text-align: right;
    width: auto;
}

.status-pill {
    width: auto;
    padding: 0 1;
    margin: 0 1;
}

.status-running   { color: $warning; }
.status-finished  { color: $success; }
.status-error     { color: $error; }
.status-stopped   { color: #666666; }
.status-paused    { color: $accent; }
.status-unknown   { color: #444444; }

/* ── Messages (supplements MessageList DEFAULT_CSS) ───────── */

.action-card {
    margin: 1 0;
    padding: 0 1;
    border: round #333333;
    height: auto;
    background: #0a0a00;
}

.action-card-header {
    text-style: bold;
    color: $warning;
}

.action-card-body {
    padding: 0 2;
    color: #cccccc;
}

.observation-card {
    margin: 0 0 1 2;
    padding: 0 1;
    border: round #333333;
    height: auto;
    background: #000a00;
}

/* ── Empty / Error States ─────────────────────────────────── */

.empty-state {
    height: 100%;
    content-align: center middle;
    color: #444444;
    text-style: italic;
}

/* ── Settings Screen ─────────────────────────────────────── */

.section {
    margin: 1 0;
    padding: 1 2;
    border: round #333333;
    height: auto;
    background: #0a0a0a;
}

.section-title {
    text-style: bold;
    color: $accent;
    margin: 0 0 1 0;
}

.field-row {
    height: 3;
    margin: 0 0 1 0;
}

.field-label {
    width: 24;
    text-style: bold;
    padding: 0 1 0 0;
    color: #888888;
}

.field-input {
    width: 1fr;
}

#new-bar {
    height: 3;
    dock: bottom;
    padding: 0;
    margin-top: 1;
}

#new-input {
    width: 1fr;
    border: tall $primary-darken-1;
}

#new-input:focus {
    border: tall $success 60%;
}

/* ── Conversation List Items ─────────────────────────────── */

.conversation-item {
    height: 3;
    padding: 0 1;
    border-bottom: hkey $primary-darken-2;
}

.conversation-item:hover {
    background: $primary-darken-2;
}

.conversation-item:focus-within {
    background: $accent 15%;
}

ConversationListItem {
    padding: 0;
}

ConversationListItem:hover {
    background: $primary-darken-2;
}

ConversationListItem.-highlight {
    background: $accent 20%;
    border-left: outer $accent;
}

.conversation-title {
    width: 1fr;
    text-style: bold;
    color: $text;
    padding: 0 1 0 0;
}

.conversation-meta {
    color: $text-muted;
    text-align: right;
    width: auto;
}

.status-pill {
    width: auto;
    padding: 0 1;
    margin: 0 1;
}

.status-running   { color: $warning; }
.status-finished  { color: $success; }
.status-error     { color: $error; }
.status-stopped   { color: $text-muted; }
.status-paused    { color: $accent; }
.status-unknown   { color: $text-muted; }

/* ── Messages (supplements MessageList DEFAULT_CSS) ───────── */

.action-card {
    margin: 1 0;
    padding: 0 1;
    border: round $warning 50%;
    height: auto;
    background: $warning 5%;
}

.action-card-header {
    text-style: bold;
    color: $warning;
}

.action-card-body {
    padding: 0 2;
    color: $text-muted;
}

.observation-card {
    margin: 0 0 1 2;
    padding: 0 1;
    border: round $success 40%;
    height: auto;
    background: $success 5%;
}

/* ── Empty / Error States ─────────────────────────────────── */

.empty-state {
    height: 100%;
    content-align: center middle;
    color: $text-muted;
    text-style: italic;
}

/* ── Settings Screen ─────────────────────────────────────── */

.section {
    margin: 1 0;
    padding: 1 2;
    border: round $primary-darken-1;
    height: auto;
    background: $surface-darken-1;
}

.section-title {
    text-style: bold;
    color: $accent;
    margin: 0 0 1 0;
}

.field-row {
    height: 3;
    margin: 0 0 1 0;
}

.field-label {
    width: 24;
    text-style: bold;
    padding: 0 1 0 0;
    color: $text-muted;
}

.field-input {
    width: 1fr;
}

#btn-row { height: 3; margin: 1 0; align: center middle; }
#settings-outer { height: 100%; padding: 1 2; background: black; }
#settings-scroll { height: 1fr; }

/* ── Welcome Screen ── */
WelcomeScreen {
    align: center middle;
    background: black;
}

#welcome-container {
    width: 60;
    height: auto;
    padding: 2 4;
    border: double $accent;
    background: #080808;
}

#welcome-title {
    width: 100%;
    text-align: center;
    text-style: bold;
    color: $accent;
    margin-bottom: 1;
}

#welcome-subtitle {
    width: 100%;
    text-align: center;
    color: #888888;
    margin-bottom: 2;
}

.setup-step {
    margin-bottom: 1;
}

.setup-step Label {
    text-style: bold;
    color: #eeeeee;
    margin-bottom: 1;
}

.help-text {
    color: #555555;
    text-style: italic;
    font-size: small;
}

#welcome-actions {
    margin-top: 1;
    align: center middle;
}

