/* Forge TUI stylesheet — Textual CSS.

Global styles and cross-cutting visual identity.
Screen-specific layout is defined inline on each Screen class.
Widget-specific styling is in each widget's DEFAULT_CSS.
*/

/* ── Global ─────────────────────────────────────────────── */

Screen {
    background: $surface;
}

/* ── Home screen (conversation list items) ──────────────── */

.conversation-item:hover {
    background: $surface-lighten-1;
}

.conversation-item:focus-within {
    background: $accent 20%;
}

ConversationListItem:hover {
    background: $surface-lighten-1;
}

ConversationListItem.-highlight {
    background: $accent 20%;
}

/* ── Messages (global, supplements MessageList DEFAULT_CSS) */

.action-card {
    margin: 1 0;
    padding: 0 1;
    border: round $warning;
    height: auto;
}

.action-card-header {
    text-style: bold;
    color: $warning;
}

.action-card-body {
    padding: 0 2;
}

.observation-card {
    margin: 0 0 1 2;
    padding: 0 1;
    border: round $success;
    height: auto;
}

/* ── Empty states ───────────────────────────────────────── */

.empty-state {
    height: 100%;
    content-align: center middle;
    color: $text-muted;
    text-style: italic;
}
