{
  "//_core": "Core & Runtime Configuration",
  "runtime": "local",
  "file_store": "local",
  "file_store_path": "storage",
  "workspace_base": "~/.Forge",
  "workspace_mount_path_in_runtime": "/workspace",
  "enable_browser": true,
  "cache_dir": "/tmp/cache",
  "max_iterations": 500,
  "max_budget_per_task": null,
  "max_budget_per_session": null,
  "max_budget_per_day": null,
  "debug": false,
  "disable_color": false,
  "conversation_max_age_seconds": 864000,
  "max_concurrent_conversations": 3,
  "vcs_user_name": "forge",
  "vcs_user_email": "Forge@forge.dev",
  "log_format": "text",
  "log_level": "INFO",
  "mcp_host": null,
  "init_git_in_empty_workspace": true,
  "run_as_Forge": true,

  "//_llm": "LLM Configuration",
  "llm_model": "claude-sonnet-4-20250514",
  "llm_api_key": null,
  "llm_base_url": null,
  "llm_temperature": 0.0,
  "llm_top_p": 1.0,
  "llm_max_output_tokens": null,
  "llm_timeout": 30,
  "llm_num_retries": 5,
  "llm_custom_llm_provider": null,
  "llm_caching_prompt": true,
  "llm_disable_vision": false,

  "//_agent": "Agent Capabilities & Permissions",
  "agent": "Orchestrator",
  "agent_enable_browsing": true,
  "agent_enable_editor": true,
  "agent_enable_cmd": true,
  "agent_enable_think": true,
  "agent_enable_finish": true,
  "agent_enable_llm_editor": false,
  "agent_enable_circuit_breaker": true,
  "agent_enable_graceful_shutdown": true,
  "agent_enable_history_truncation": true,
  "agent_enable_condensation_request": false,
  "confirmation_mode": false,
  "security_analyzer": null,

  "//_condenser": "Condenser (Context Management)",
  "enable_default_condenser": true,
  "condenser_type": "llm",
  "condenser_keep_first": 1,
  "condenser_max_events": 100,
  "condenser_attention_window": 100,
  "condenser_llm_config": null,
  "condenser_max_event_length": 10000,
  "condenser_token_budget": null,

  "//_graph_rag": "Graph RAG",
  "graph_rag_enabled": false,
  "graph_rag_persistence_path": "graph_rag_data",
  "graph_rag_graph_depth": 2,
  "graph_rag_max_seed_results": 10,

  "//_file_uploads": "File Uploads",
  "file_uploads_max_file_size_mb": 100,
  "file_uploads_restrict_file_types": false,
  "file_uploads_allowed_extensions": [".txt", ".py", ".js", ".md"],

  "//_trajectory": "Trajectory (Recording)",
  "save_trajectory_path": null,
  "replay_trajectory_path": null,
  "save_screenshots_in_trajectory": false,

  "//_knowledge_base": "Knowledge Base",
  "kb_enabled": true,
  "kb_search_top_k": 5,
  "kb_relevance_threshold": 0.7,
  "kb_auto_search": true,
  "kb_search_strategy": "hybrid"
}
