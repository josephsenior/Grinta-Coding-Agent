{
  "version": "0.55.0",
  "description": "Autonomous local-first CLI coding agent",
  "homepage": "https://github.com/josephsenior/Grinta-Coding-Agent",
  "license": "MIT",
  "depends": "python312",
  "url": "https://files.pythonhosted.org/packages/source/g/grinta-ai/grinta-ai-0.55.0.tar.gz",
    "hash": "c1c0c8323a86b2b8abf0e0bb8cba37ba160eea2d2ebf144c5ff1c57fe8ec7793"
  "extract_dir": "grinta_ai-0.55.0",
  "installer": {
    "script": [
      "python -m venv \"$dir\\.venv\"",
      "& \"$dir\\.venv\\Scripts\\python.exe\" -m pip install --upgrade pip",
      "& \"$dir\\.venv\\Scripts\\python.exe\" -m pip install --no-warn-script-location \"$dir\""
    ]
  },
  "bin": [
    [".venv\\Scripts\\python.exe", "grinta", "-m backend.cli.entry"]
  ],
  "checkver": "github",
  "autoupdate": {
    "url": "https://files.pythonhosted.org/packages/source/g/grinta-ai/grinta-ai-$version.tar.gz",
    "extract_dir": "grinta_ai-$version"
  }
}
