</label>\n                        <input type=\"text\" class=\"form-control\" id=\"title\" name=\"title\" required>\n                    </div>\n                    <div class=\"mb-3\">\n                        <label for=\"description\" class=\"form-label\">Description</label>\n                        <textarea class=\"form-control\" id=\"description\" name=\"description\" rows=\"3\"></textarea>\n                    </div>\n                    <div class=\"mb-3\">\n                        <label for=\"due_date\" class=\"form-label\">Due Date</label>\n                        <input type=\"date\" class=\"form-control\" id=\"due_date\" name=\"due_date\">\n                    </div>\n                    <div class=\"mb-3\">\n                        <label for=\"priority\" class=\"form-label\">Priority</label>\n                        <select class=\"form-select\" id=\"priority\" name=\"priority\">\n                            <option value=\"Low\">Low</option>\n                            <option value=\"Medium\" selected>Medium</option>\n                            <option value=\"High\">High</option>\n                        </select>\n                    </div>\n                    <button type=\"submit\" class=\"btn btn-primary w-100\">Add Task</button>\n                </form>\n            </div>\n        </div>\n    </div>\n    <div class=\"col-md-8\">\n        <div class=\"card\">\n            <div class=\"card-header d-flex justify-content-between align-items-center\">\n                <h5 class=\"mb-0\">Your Tasks</h5>\n                <span class=\"badge bg-info\">{{ tasks|length }} Tasks</span>\n            </div>\n            <div class=\"card-body\">\n                {% if tasks %}\n                <div class=\"table-responsive\">\n                    <table class=\"table table-hover\">\n                        <thead>\n                            <tr>\n                                <th>Status</th>\n                                <th>Task</th>\n                                <th>Priority</th>\n                                <th>Due Date</th>\n                                <th>Actions</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            {% for task in tasks %}\n                            <tr class=\"{{ 'table-light' if task.is_done else '' }}\">\n                                <td>\n                                    <form method=\"POST\" action=\"{{ url_for('toggle_task', task_id=task.id) }}\">\n                                        <div class=\"form-check\">\n                                            <input class=\"form-check-input\" type=\"checkbox\" {% if task.is_done %}checked{% endif %} onchange=\"this.form.submit()\">\n                                        </div>\n                                    </form>\n                                </td>\n                                <td>\n                                    <div class=\"{% if task.is_done %}text-decoration-line-through text-muted{% endif %}\">\n                                        <strong>{{ task.title }}</strong>\n                                        {% if task.description %}\n                                        <br><small class=\"text-muted\">{{ task.description }}</small>\n                                        {% endif %}\n                                    </div>\n                                </td>\n                                <td>\n                                    <span class=\"badge {% if task.priority == 'High' %}bg-danger{% elif task.priority == 'Medium' %}bg-warning text-dark{% else %}bg-success{% endif %}\">\n                                        {{ task.priority }}\n                                    </span>\n                                </td>\n                                <td>\n                                    {% if task.due_date %}\n                                    <small class=\"{{ 'text-danger' if task.is_overdue and not task.is_done else '' }}\">\n                                        {{ task.due_date.strftime('%Y-%m-%d') }}\n                                    </small>\n                                    {% else %}\n                                    -\n                                    {% endif %}\n                                </td>\n                                <td>\n                                    <form method=\"POST\" action=\"{{ url_for('delete_task', task_id=task.id) }}\" style=\"display: inline;\">\n                                        <button type=\"submit\" class=\"btn btn-sm btn-outline-danger\" onclick=\"return confirm('Are you sure?')\">\n                                            <i class=\"bi bi-trash\"></i> Delete\n                                        </button>\n                                    </form>\n                                </td>\n                            </tr>\n                            {% endfor %}\n                        </tbody>\n                    </table>\n                </div>\n                {% else %}\n                <p class=\"text-center text-muted my-4\">No tasks found. Add one to get started!</p>\n                {% endif %}\n            </div>\n        </div>\n    </div>\n</div>\n{% endblock %}\n", "old_str": null, "new_str": null, "insert_line": null, "view_range": null, "content": "", "start": 1, "end": -1, "thought": "", "security_risk": -1, "impl_source": "file_editor"}}