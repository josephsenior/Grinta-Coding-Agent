{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Test Server Health",
			"type": "shell",
			"command": "python test_server_health.py",
			"isBackground": false
		},
		{
			"label": "Test Agent Flow",
			"type": "shell",
			"command": "python test_agent.py",
			"isBackground": false
		},
		{
			"label": "Run Agent Script",
			"type": "shell",
			"command": "python test_agent.py > agent_test_out.txt 2>&1",
			"isBackground": false
		},
		{
			"label": "Test Ports",
			"type": "shell",
			"command": "python test_ports.py > test_ports_out.txt 2>&1",
			"isBackground": false
		},
		{
			"label": "Live Server",
			"type": "shell",
			"command": "uv run python start_server.py",
			"isBackground": true
		},
		{
			"label": "Test Ports Again",
			"type": "shell",
			"command": "python test_ports.py > test_ports_out.txt 2>&1",
			"isBackground": false
		},
		{
			"label": "Debug Live Server",
			"type": "shell",
			"command": "uv run python start_server.py > server_start_log.txt 2>&1",
			"isBackground": true
		},
		{
			"label": "Run Uvicorn Task",
			"type": "shell",
			"command": "uv run uvicorn backend.api.socketio_asgi_app:app --port 3030",
			"isBackground": true
		},
		{
			"label": "Run TEst",
			"type": "shell",
			"command": "python test_agent.py > test_results.txt 2>&1",
			"isBackground": false
		},
		{
			"label": "Run TEst2",
			"type": "shell",
			"command": "python test_agent.py > test_results2.txt 2>&1",
			"isBackground": false
		},
		{
			"label": "FINAL_TEST",
			"type": "shell",
			"command": "python test_agent.py > FINAL_TEST_RUN.txt 2>&1",
			"isBackground": false
		}
	]
}
