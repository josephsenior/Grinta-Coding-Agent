# This file lives in the Grinta repo only — it is loaded before any workspace import.
# Optional: ``-p <repo>/.env`` can override keys per client repo (e.g. API keys).
#
# File logs: ``<Grinta>/logs/workspaces/<name>__<hash>/`` (one folder per PROJECT_ROOT).
# Default LOG_LEVEL=INFO keeps LOG_TO_FILE=false — set one of:
# LOG_TO_FILE=true
# LOG_LEVEL=DEBUG
# DEBUG_LLM=true

# Optional: directory that holds canonical settings.json (default: process cwd)
# APP_ROOT=C:\path\to\app

# Open project folder (agent workspace)
# APP_PROJECT_ROOT=C:\path\to\your\repo

# LocalFileStore disk root (sessions, etc.)
# LOCAL_DATA_ROOT=C:\path\to\data

# Optional: Enable intelligent web browsing
BROWSER_USE_API_KEY=your_api_key_here
# LLM_API_KEY=...  # optional if llm_api_key is in settings.json
# GEMINI_API_KEY=your_gemini_key
# OPENROUTER_API_KEY=your_openrouter_key