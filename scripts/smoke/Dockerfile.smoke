FROM python:3.12-slim

# Clean-room Docker container for verifying that `pip install grinta`
# (and its optional extras) installs and imports cleanly on a fresh OS.
#
# Usage:
#   # Build:
#   docker build -f scripts/smoke/Dockerfile.smoke -t grinta-smoke .
#
#   # Base install only (~5 MB on top of slim):
#   docker run --rm grinta-smoke
#
#   # With [rag] extra:
#   docker run --rm -e EXTRAS=rag grinta-smoke
#
#   # With everything:
#   docker run --rm -e EXTRAS=all grinta-smoke
#
#   # Test a local wheel instead of PyPI:
#   docker build -f scripts/smoke/Dockerfile.smoke -t grinta-smoke .
#   docker run --rm -v "$(pwd)/dist:/dist" grinta-smoke

RUN apt-get update \
 && apt-get install -y --no-install-recommends ripgrep ca-certificates \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /smoke
COPY scripts/smoke/smoke_install.sh /smoke/smoke_install.sh
COPY backend/scripts/verify/verify_optional_imports.py /smoke/backend/scripts/verify/verify_optional_imports.py
RUN chmod +x /smoke/smoke_install.sh

ENV WHEEL_DIR=/dist
ENV EXTRAS=""

CMD ["/bin/bash", "-c", "/smoke/smoke_install.sh $EXTRAS"]
